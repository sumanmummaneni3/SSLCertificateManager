# Build artifacts
*.zip
target/
*.class
*.jar
!server/src/test/resources/**/*.jar
!server/src/main/resources/agent/certguard-agent.jar

# Generated by build.sh / GitHub Actions — never commit, always rebuilt
server/src/main/resources/static/

# Maven
.mvn/
!**/mvn/wrapper/maven-wrapper.jar

# Frontend
ui/node_modules/
ui/dist/
ui/.env.local

# IDE
.idea/
*.iml
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Docker volumes / generated certs
server/certs/*.pem
server/certs/*.key
server/certs/*.crt
server/postgres/data/
server/monitoring/grafana/data/

# Environment secrets
.env
!.env.example

# Claude Code agent memory and session files — but track shared project commands
.claude/
!.claude/commands/
prompty.txt
ui/*.txt
