# ============================================================
# CertGuard Auth Service — environment variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# Auth-service own database (runs in the auth-db sidecar container)
AUTH_DB_URL=jdbc:postgresql://auth-db:5432/certguard_auth
AUTH_DB_USERNAME=auth_user
AUTH_DB_PASSWORD=changeme

# Main certguard database (shared with the main stack; service name is 'postgres' on certguard-net)
MAIN_DB_URL=jdbc:postgresql://postgres:5432/certguard
MAIN_DB_USERNAME=certguard_user
MAIN_DB_PASSWORD=changeme

# JWT — generate with: openssl rand -hex 48
AUTH_JWT_SECRET=replace_with_at_least_64_character_secret_generated_with_openssl_rand_hex_48
AUTH_JWT_EXPIRATION_SECONDS=28800

# Google OAuth2 — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth2 — https://portal.azure.com/
MICROSOFT_CLIENT_ID=your-microsoft-app-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-app-client-secret
MICROSOFT_TENANT_ID=common

# CORS — comma-separated list of allowed frontend origins
AUTH_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=300

# Callback base URL — must match the redirect URIs registered in Google/Microsoft consoles
AUTH_CALLBACK_BASE_URL=http://localhost:8090

# Server port
AUTH_SERVER_PORT=8090

# Docker network shared with the main certguard stack (run: docker network ls | grep certguard)
CERTGUARD_NET_NAME=certguard_certguard-net

# Email / SMTP (used for verification and password-reset emails)
# Mailgun example: host=smtp.mailgun.org port=587 username=postmaster@mg.yourdomain.com
# SendGrid example: host=smtp.sendgrid.net port=587 username=apikey password=SG.xxx
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=postmaster@mg.yourdomain.com
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=CertGuard
